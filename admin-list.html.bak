<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>笔记管理列表</title>
<script src="./data.js?v=1"></script>
<style>
/* 样式保留您的原始内容，此处只展示关键改动 */
*{
  margin:0;padding:0;box-sizing:border-box;
  font-family: system-ui, sans-serif;
}
body{
  background:#f7f8fc;
  padding:0 2px;
  max-width:100%;
  margin:0 auto;
}
header{
  margin-bottom:16px;
  padding-bottom:10px;
  border-bottom:1px solid #e4e7f3;
}
.header-top{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:10px;
  flex-wrap:wrap;
  gap:8px;
}
h1{
  font-size:22px;
  color:#1d2133;
}
.btn-group-header{
  display:flex;
  flex-wrap:wrap;
  gap:6px;
}
.back-btn{
  padding:6px 10px;
  background:#e4e7f3;
  border:none;
  border-radius:8px;
  font-size:13px;
  cursor:pointer;
  transition:0.15s;
}
.back-btn:hover{
  background:#d9dcf0;
}
.new-btn{
  padding:6px 10px;
  background:#6366F1;
  color:#fff;
  border:none;
  border-radius:8px;
  font-size:13px;
  cursor:pointer;
  transition:0.15s;
}
.new-btn:hover{
  background:#4f46e5;
}
.blog-btn{
  padding:6px 10px;
  background:#10b981;
  color:#fff;
  border:none;
  border-radius:8px;
  font-size:13px;
  cursor:pointer;
  transition:0.15s;
}
.blog-btn:hover{
  background:#059669;
}
.album-btn{
  padding:6px 10px;
  background:#f97316;
  color:#fff;
  border:none;
  border-radius:8px;
  font-size:13px;
  cursor:pointer;
  transition:0.15s;
}
.album-btn:hover{
  background:#ea580c;
}
.item-box{
  background:#fff;
  border-radius:10px;
  padding:12px;
  box-shadow:0 2px 10px rgba(99,102,241,0.07);
  margin-bottom:10px;
  display:flex;
  justify-content:space-between;
  align-items:center;
  flex-wrap:wrap;
  gap:10px;
  transition:0.15s;
}
.item-box:hover{
  box-shadow:0 3px 12px rgba(99,102,241,0.12);
}
.item-info h3{
  font-size:16px;
  color:#1a1e32;
  margin-bottom:4px;
}
.item-info p{
  font-size:13px;
  color:#888;
  display:flex;
  align-items:center;
  flex-wrap:wrap;
  gap:6px;
}
.tag-group {
  display: flex;
  gap: 4px;
  flex-wrap: wrap;
}
.tag{
  font-size:11px;
  padding:2px 6px;
  border-radius:12px;
}
.tag-note{background: #e8eaff;color:#3950cc;}
.tag-doc{background:#e6f8ee;color:#148246;}
.tag-custom{background:#fff0e6;color:#b8460c;}
.tag-编程{background:#e1f5fe;color:#0277bd;}
.btn-group{
  display:flex;
  gap:6px;
}
.edit-btn{
  background:#6366F1;
  color:#fff;
  border:none;
  padding:6px 10px;
  border-radius:6px;
  cursor:pointer;
  transition:0.15s;
}
.edit-btn:hover{
  background:#4f46e5;
}
.del-btn{
  background:#f43f5e;
  color:#fff;
  border:none;
  padding:6px 10px;
  border-radius:6px;
  cursor:pointer;
  transition:0.15s;
}
.del-btn:hover{
  background:#e11d48;
}
.empty{
  text-align:center;
  padding:50px 2px;
  color:#999;
}
.login-modal{
  position:fixed;
  inset:0;
  background:rgba(0,0,0,0.5);
  display:flex;
  align-items:center;
  justify-content:center;
  z-index:999;
  cursor:pointer;
}
.login-box{
  background:#fff;
  padding:20px;
  border-radius:12px;
  width:90%;
  max-width:320px;
  cursor:default;
}
.login-box input[type="password"]{
  width:100%;
  padding:10px;
  margin:10px 0;
  border:1px solid #ddd;
  border-radius:8px;
  outline:none;
}
.login-box input[type="password"]:focus{
  border-color:#6366F1;
}
.login-box button{
  width:100%;
  padding:10px;
  background:#6366F1;
  color:#fff;
  border:none;
  border-radius:8px;
  margin-top:8px;
  cursor:pointer;
  transition:0.15s;
}
.login-box button:hover{
  background:#4f46e5;
}
.remember-row{
  display:flex;
  gap:6px;
  align-items:center;
}
</style>
</head>
<body>
<div id="loginWrap" class="login-modal">
  <div class="login-box">
    <h3>管理员登录</h3>
    <input type="password" id="pwdInput" placeholder="输入管理员密码">
    <div class="remember-row">
      <input type="checkbox" id="rememberCheck">
      <label for="rememberCheck">记住密码</label>
    </div>
    <button onclick="doLogin()">登录</button>
  </div>
</div>

<header style="display:none" id="mainWrap">
  <div class="header-top">
    <h1>笔记管理后台</h1>
    <div class="btn-group-header">
      <button class="blog-btn" onclick="window.open('https://sxgpyjg.github.io','_blank')">博客主页</button>
      <button class="album-btn" onclick="window.open('https://sxgpyjg.github.io/blog','_blank')">图文相册</button>
      <button class="new-btn" onclick="location.href='edit.html'">+新建笔记</button>
      <button class="back-btn" onclick="forceReloadRemote()">刷新数据</button>
      <button class="back-btn" onclick="copyCleanJson()">复制纯净data.js</button>
      <button class="back-btn" onclick="location.href='index.html'">笔记首页</button>
      <button class="back-btn" onclick="logoutAdmin()">退出登录</button>
    </div>
  </div>
</header>
<div id="listWrap"></div>

<script>
const ADMIN_PASSWORD = "admin123";
const PWD_STORE_KEY = "admin_save_pwd";
const LOGIN_EXPIRE_KEY = "admin_login_expire";
const LOGIN_EXPIRE_HOUR = 8;
let remoteNoteData = [];

function escapeHtml(str){
  const s = String(str ?? "");
  return s.replace(/&/g,"&amp;")
          .replace(/</g,"&lt;")
          .replace(/>/g,"&gt;")
          .replace(/"/g,"&quot;")
          .replace(/'/g,"&#039;");
}

function getTagClassByName(name) {
  switch(name) {
    case 'note': return 'tag-note';
    case 'doc': return 'tag-doc';
    case '编程': return 'tag-编程';
    default: return 'tag-custom';
  }
}

// ========== 标签颜色：从笔记对象 item.tagColors 获取（修改点） ==========
function getTagStyle(tagName, colorMap) {
  const color = (colorMap && colorMap[tagName]) || '';
  if (color) {
    const r = parseInt(color.slice(1,3), 16) / 255;
    const g = parseInt(color.slice(3,5), 16) / 255;
    const b = parseInt(color.slice(5,7), 16) / 255;
    const brightness = 0.299 * r + 0.587 * g + 0.114 * b;
    const textColor = brightness > 0.5 ? '#222' : '#fff';
    return `background-color:${color};color:${textColor};`;
  }
  return '';
}

function forceReloadRemote(){
  const url = new URL(location.href);
  url.searchParams.set("_dt", Date.now());
  location.href = url.toString();
}

window.addEventListener("load", ()=>{
  setTimeout(()=>{
    if(window.NOTE_DATA && Array.isArray(window.NOTE_DATA)){
      remoteNoteData = JSON.parse(JSON.stringify(window.NOTE_DATA));
      remoteNoteData.forEach(item => {
        if (!Array.isArray(item.tags) && item.type) {
          item.tags = [item.type];
        }
      });
      saveAllNotes(remoteNoteData);
    }
    render();
    // 不再需要 refreshAllTagStyles，颜色已在 render 中直接写入
  }, 300);
});

function loadAllNotes(){
  if(remoteNoteData.length > 0) return remoteNoteData;
  const raw = localStorage.getItem("notes");
  try{
    const list = raw ? JSON.parse(raw) : [];
    list.forEach(item => {
      if (!Array.isArray(item.tags) && item.type) {
        item.tags = [item.type];
      }
    });
    return list;
  }catch(e){
    return [];
  }
}

function saveAllNotes(list){
  localStorage.setItem("notes", JSON.stringify(list));
  window.NOTE_DATA = list;
}

function logoutAdmin(){
  localStorage.removeItem(PWD_STORE_KEY);
  localStorage.removeItem(LOGIN_EXPIRE_KEY);
  location.reload();
}

function doLogin(){
  const inputPwd = document.getElementById("pwdInput").value.trim();
  const remember = document.getElementById("rememberCheck").checked;
  if(inputPwd !== ADMIN_PASSWORD){
    alert("密码错误");
    return;
  }
  if(remember){
    localStorage.setItem(PWD_STORE_KEY, inputPwd);
    const expire = Date.now() + LOGIN_EXPIRE_HOUR * 3600 * 1000;
    localStorage.setItem(LOGIN_EXPIRE_KEY, expire);
  }else{
    localStorage.removeItem(PWD_STORE_KEY);
    localStorage.removeItem(LOGIN_EXPIRE_KEY);
  }
  document.getElementById("loginWrap").style.display = "none";
  document.getElementById("mainWrap").style.display = "block";
  window.NOTE_DATA = loadAllNotes();
  sessionStorage.setItem('cleanNoteSnapshot', JSON.stringify([...window.NOTE_DATA]));
  render();
}

document.getElementById("loginWrap").addEventListener("click", function(e){
  if(e.target === this){
    this.style.display = "none";
  }
});

(function autoLogin(){
  const saved = localStorage.getItem(PWD_STORE_KEY);
  const expireTs = Number(localStorage.getItem(LOGIN_EXPIRE_KEY)) || 0;
  const now = Date.now();
  if(expireTs < now){
    localStorage.removeItem(PWD_STORE_KEY);
    localStorage.removeItem(LOGIN_EXPIRE_KEY);
    return;
  }
  if(saved === ADMIN_PASSWORD){
    document.getElementById("loginWrap").style.display = "none";
    document.getElementById("mainWrap").style.display = "block";
    window.NOTE_DATA = loadAllNotes();
    sessionStorage.setItem('cleanNoteSnapshot', JSON.stringify([...window.NOTE_DATA]));
    render();
  }
})();

window.delNote = function(id){
  if(!confirm("确认永久删除这条笔记？删除后无法恢复")){
    return;
  }
  // 直接使用 window.NOTE_DATA（它已经从 localStorage 同步）
  let list = window.NOTE_DATA || [];
  list = list.filter(item => item.id !== id);
  saveAllNotes(list);
  // 同步更新 remoteNoteData，避免后续 loadAllNotes 返回旧数据
  remoteNoteData = list;
  sessionStorage.setItem('cleanNoteSnapshot', JSON.stringify(list));
  alert("已删除并更新纯净快照；复制纯净data.js后替换仓库文件并git push才能全局生效");
  render();
}

function render(){
  const wrap = document.getElementById('listWrap');
  let list = window.NOTE_DATA || loadAllNotes();
  if(!Array.isArray(list)) list = [];
  const realList = [...list];
  if(realList.length === 0){
    wrap.innerHTML = '<div class="empty">暂无笔记，点击上方【+新建笔记】创建第一条</div>';
    return;
  }
  let html = '';
  realList.sort((a,b)=>new Date(b.date) - new Date(a.date)).forEach(item=>{
    const title = escapeHtml(item.title);
    const date = escapeHtml(item.date);
    // 多标签渲染 + 颜色同步（直接从 item.tagColors 传入）
    const tagHtml = (item.tags || []).map(tag => {
      const cls = getTagClassByName(tag);
      return `<span class="tag ${cls}" data-tag="${escapeHtml(tag)}" style="${getTagStyle(tag, item.tagColors)}">${escapeHtml(tag)}</span>`;
    }).join('');
    html += `
    <div class="item-box">
      <div class="item-info">
        <h3>${title}</h3>
        <p>${date} | <div class="tag-group">${tagHtml}</div></p>
      </div>
      <div class="btn-group">
        <button class="edit-btn" onclick="location.href='edit.html?id=${item.id}'">编辑</button>
        <button class="del-btn" onclick="delNote('${item.id}')">删除</button>
      </div>
    </div>
    `
  })
  wrap.innerHTML = html;
}

function copyCleanJson(){
  const freshList = loadAllNotes();
  sessionStorage.setItem('cleanNoteSnapshot', JSON.stringify(freshList));
  const fullJsText = `window.NOTE_DATA = ${JSON.stringify(freshList, null, 2)}`;
  navigator.clipboard.writeText(fullJsText).then(()=>{
    alert("复制成功！已存入会话快照，编辑器可点「加载纯净管理快照」；\n粘贴覆盖仓库data.js并git push origin main全局生效");
  }).catch(()=>{
    const tempTextarea = document.createElement('textarea');
    tempTextarea.value = fullJsText;
    document.body.appendChild(tempTextarea);
    tempTextarea.select();
    document.execCommand('copy');
    document.body.removeChild(tempTextarea);
    alert("兼容复制成功，格式为完整data.js内容，已存入会话快照");
  });
}
</script>
</body>
</html>
