function insertQuote(){
  const tpl = "> ";
  if(currentEditMode === "rich"){
    document.execCommand("insertText",false,tpl);
    richBox.focus();
  }else{
    mdBox.value += tpl;
    saveMdRecord();
    renderMdPreview();
    mdBox.onkeydown = function(e){
      if(e.key === "Enter"){
        const lineStart = getLineStart(mdBox.value, mdBox.selectionStart);
        const lineText = mdBox.value.slice(lineStart, mdBox.selectionStart);
        if(lineText.startsWith("> ")){
          e.preventDefault();
          const insertPos = mdBox.selectionStart;
          mdBox.value = mdBox.value.slice(0,insertPos) + "\n> " + mdBox.value.slice(insertPos);
          mdBox.selectionStart = insertPos + 3;
          mdBox.selectionEnd = insertPos + 3;
          saveMdRecord();
          renderMdPreview();
        }
      }
    }
  }
}
