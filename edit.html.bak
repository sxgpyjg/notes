function insertMdCode(){
  const richTpl = `<pre style="background:#f5f5f5;padding:10px;border-radius:6px;white-space:pre-wrap;"><code></code></pre><br><br>`;
  const mdTpl = "```\n\n```\n";
  if(currentEditMode === "rich"){
    richBox.focus();
    document.execCommand("insertHTML", false, richTpl);
    checkFormatActive();
  }else{
