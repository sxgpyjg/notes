<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover, maximum-scale=1, user-scalable=no">
<title>笔记编辑器（完整移植纯写作原生交互）</title>
<script src="./data.js"></script>
<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:system-ui,-apple-system,sans-serif;
}
html,body{
  height:100%;
  overflow-x:hidden;
}
body{
  background:#f7f8fc;
  padding:10px 10px 110px;
}

/* 双列按钮 绝对均分对称 */
.tool-box,.tool-row,.save-row{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:8px;
  margin:8px 0 10px;
}

.tool-bar{
  display:flex;
  gap:8px;
  margin-bottom:10px;
}
.link-btn{
  border:0;
  border-radius:10px;
  padding:9px 0;
  font-size:14px;
  color:#fff;
  flex:1;
  min-width:0;
}
.blog-link{
  background:#10b981;
}
.album-link{
  background:#f97316;
}

.tool-btn{
  background:#ffffff;
  border:0;
  border-radius:8px;
  padding:10px 6px;
  font-size:14px;
  box-shadow:0 1px 4px rgba(99,102,241,0.06);
  transition:0.2s;
}
.tool-btn:active{
  background:#edefff;
}

.save-btn{
  background:#6366F1;
  color:white;
  border:0;
  border-radius:8px;
  padding:11px 0;
  width:100%;
  font-size:15px;
  box-shadow:0 2px 6px rgba(99,102,241,0.15);
}
.save-btn-time{
  background:#4f46e5;
}
#exportFullBackup{
  background:#22c55e;
}
#importBackup{
  background:#f59e0b;
}
.save-btn:active{
  opacity:0.9;
}

.title-input,.type-input{
  width:100%;
  border:1px solid #e0e3f0;
  border-radius:8px;
  padding:10px;
  font-size:15px;
  margin-bottom:10px;
  outline:none;
  background:#fff;
}
.title-input:focus,.type-input:focus{
  border-color:#6366F1;
}

.edit-toolbar-wrap{
  position:fixed;
  bottom:0;
  left:0;
  width:100%;
  background:#fff;
  border-top:1px solid #e0e3f0;
  z-index:999;
  padding-bottom: env(safe-area-inset-bottom);
}
.toolbar-main{
  display:flex;
  flex-wrap:wrap;
  gap:1px;
  padding:4px 6px;
  align-items:center;
}
.toolbar-more{
  display:none;
  padding:4px 6px;
  border-top:1px solid #eee;
  grid-template-columns:repeat(8, 1fr);
  gap:0px;
}
.toolbar-more.show{
  display:grid;
}

/* 底部小图标按钮 统一大小 */
.icon-btn{
  border:1px solid #ddd;
  background:#fff;
  border-radius:2px;
  width:24px;
  height:24px;
  font-size:13px;
  display:flex;
  align-items:center;
  justify-content:center;
  cursor:pointer;
  position:relative;
  touch-action:none;
}
.icon-btn:active{
  background:#eef2ff;
}
.icon-btn.active-format{
  background:#6366F1 !important;
  color:#fff !important;
  border-color:#4f46e5 !important;
}
.icon-btn:hover::after{
  content:attr(data-tip);
  position:absolute;
  bottom:110%;
  left:50%;
  transform:translateX(-50%);
  background:#222;
  color:#fff;
  font-size:10px;
  padding:2px 4px;
  border-radius:3px;
  white-space:nowrap;
  z-index:9999;
}

.edit-toolbar select{
  border:1px solid #ddd;
  border-radius:3px;
  padding:2px;
  font-size:11px;
  height:24px;
  width:38px;
}
.color-input{
  width:24px;
  height:24px;
  border:none;
  cursor:pointer;
  border-radius:3px;
}

.editor-wrap{
  margin-bottom:10px;
}
.rich-editor{
  width:100%;
  min-height:280px;
  border:1px solid #e0e3f0;
  border-radius:8px;
  padding:10px;
  font-size:15px;
  outline:none;
  background:#fff;
  line-height:1.7;
  position:relative;
}
.rich-editor img{
  max-width:100%;
  height:auto;
  border-radius:6px;
  margin:8px 0;
  display:block;
  content-visibility:auto;
  loading:lazy;
}
.md-editor{
  width:100%;
  min-height:280px;
  border:1px solid #e0e3f0;
  border-radius:8px;
  padding:10px;
  font-size:15px;
  outline:none;
  background:#fff;
  line-height:1.7;
  font-family:monospace;
  resize:vertical;
}
.md-preview{
  width:100%;
  min-height:180px;
  border:1px solid #e0e3f0;
  border-radius:8px;
  padding:10px;
  background:#fff;
  margin-top:6px;
  line-height:1.7;
}

/* 模式切换按钮 左右完全一样大 */
.mode-switch{
  margin-bottom:8px;
  display:flex;
  gap:8px;
}
.mode-switch button{
  flex:1;
  padding:8px 0;
  border-radius:8px;
  border:1px solid #6366F1;
  background:#fff;
  color:#6366F1;
  font-size:14px;
}
.mode-switch button.active{
  background:#6366F1;
  color:#fff;
}

#imgFileInput,#backupFileInput,#hiddenImgFile1,#hiddenImgFile2{
  opacity:0;
  position:absolute;
  width:0;
  height:0;
  pointer-events:auto;
}
.warn{
  color:#e53e3e;
  font-size:12px;
  margin-bottom:8px;
  background:#fff2f4;
  padding:5px 8px;
  border-radius:6px;
}
.tip-green{
  color:#16a34a;
  font-size:12px;
  margin-bottom:8px;
  background:#f0fdf4;
  padding:5px 8px;
  border-radius:6px;
}
.tip-red{
  color:#dc2626;
  font-weight:bold;
  font-size:13px;
  margin-bottom:8px;
  background:#fee2e2;
  padding:6px 8px;
  border-radius:6px;
}

.login-modal{
  position:fixed;
  inset:0;
  background:rgba(0,0,0,0.5);
  display:flex;
  align-items:center;
  justify-content:center;
  z-index:9999;
}
.login-box{
  background:#fff;
  padding:18px;
  border-radius:10px;
  width:90%;
  max-width:300px;
}
.login-box input[type="password"]{
  width:100%;
  padding:9px;
  margin:8px 0;
  border:1px solid #ddd;
  border-radius:6px;
}
.login-box button{
  width:100%;
  padding:9px;
  background:#6366F1;
  color:#fff;
  border:none;
  border-radius:6px;
}

.img-collapse{
  border:1px solid #dbeafe;
  border-radius:8px;
  margin:8px 0;
  overflow:hidden;
}
.img-collapse-head{
  padding:10px 12px;
  background:#eff6ff;
  cursor:pointer;
  display:flex;
  justify-content:space-between;
  align-items:center;
  font-weight:500;
  font-size:14px;
}
.img-collapse-body{
  padding:10px;
  display:none;
}
.img-collapse-body.show{
  display:block;
}
.arrow{
  transition:transform 0.2s;
}
.arrow.rotate{
  transform:rotate(180deg);
}

.img-quick-btn{
  background:#eef2ff;
  color:#4338ca;
  border:0;
  border-radius:4px;
  padding:3px 6px;
  font-size:12px;
  margin-bottom:6px;
}

body.keyboard-opened{
  padding-bottom:160px;
}

.modal-mask{
  position:fixed;
  inset:0;
  background:rgba(0,0,0,0.55);
  z-index:99999;
  display:flex;
  align-items:center;
  justify-content:center;
  padding:10px;
}
.modal-box{
  width:100%;
  max-width:400px;
  background:#fff;
  border-radius:12px;
  padding:18px;
}
.modal-input{
  width:100%;
  border:none;
  border-bottom:1px solid #999;
  padding:7px 0;
  font-size:15px;
  outline:none;
  background:transparent;
}
.modal-btn{
  background:transparent;
  border:none;
  color:#009688;
  font-size:16px;
}

.rich-editor table {
  width:100%;
  border-collapse: collapse;
  margin:6px 0;
}
.rich-editor th,
.rich-editor td {
  border:1px solid #999;
  padding:5px 6px;
  min-width:50px;
}
.md-preview table {
  width:100%;
  border-collapse: collapse;
  margin:6px 0;
}
.md-preview th,
.md-preview td {
  border:1px solid #999;
  padding:5px 6px;
  min-width:50px;
}

</style>
</head>
<body>
<div id="loginWrap" class="login-modal">
  <div class="login-box">
    <h3>管理员验证</h3>
    <input type="password" id="pwdInput" placeholder="输入管理员密码">
    <button onclick="checkPwd()">确认进入</button>
  </div>
</div>
<div id="mainWrap" style="display:none">
<div class="tool-bar">
  <button class="link-btn blog-link" onclick="window.open('https://sxgpyjg.github.io','_blank')">博客主页</button>
  <button class="link-btn album-link" onclick="window.open('https://sxgpyjg.github.io/blog','_blank')">图文相册</button>
</div>
<div class="tool-box">
<button class="tool-btn" onclick="location.href='admin-list.html'">返回管理列表</button>
<button class="tool-btn" onclick="location.href='index.html'">网站首页</button>
</div>
<div class="img-collapse">
  <div class="img-collapse-head" onclick="toggleImgPanel()">
    <span>图片素材面板</span>
    <span class="arrow" id="imgArrow">▼</span>
  </div>
  <div class="img-collapse-body" id="imgPanelBody">
    <div class="tip-red">【高危禁止】cd/cp/git终端命令不要粘贴到data.js，会损坏笔记文件！</div>
    <div class="tip-green">图片复制规则：选中图片仅生成对应cp指令，不会读取手机全部图片</div>
    <div class="warn">不生成base64图片，仅保存images文件夹相对路径，图片需手动上传仓库
    <br>vivo手机多选提示：相册长按批量勾选，单次单选可多次叠加</div>
    <div class="tool-row">
    <button class="tool-btn" id="copyJsonBtn">一键复制完整data.js代码（仅本段可粘贴nano）</button>
    <button class="tool-btn" id="showTemplateBtn">生成选中图片复制命令</button>
    </div>
    <div class="tool-row">
    <button class="tool-btn" id="insertCodeBtn" onclick="insertMdCode()">插入代码块模板</button>
    </div>
    <input type="file" id="imgFileInput" multiple accept="image/*">
  </div>
</div>
<div class="save-row">
  <button class="save-btn" id="saveNormalBtn">下载 data.js（无时间戳）</button>
  <button class="save-btn save-btn-time" id="saveTimeBtn">下载 data_时间戳.js（留存旧文件）</button>
</div>
<div class="save-row">
  <button class="save-btn" id="exportFullBackup">导出完整备份notes.json</button>
  <button class="save-btn" id="importBackup">导入本地备份文件</button>
  <input type="file" id="backupFileInput" accept=".json,.js">
</div>
<input class="title-input" placeholder="填写笔记标题">
<input class="type-input" placeholder="自定义分类（开发笔记/随笔/教程）">
<div class="mode-switch">
  <button id="modeRich" class="active" onclick="switchMode('rich')">富文本可视化编辑</button>
  <button id="modeMd" onclick="switchMode('md')">Markdown纯文本</button>
</div>
<div class="edit-toolbar-wrap">
  <div class="toolbar-main">
    <button class="icon-btn" data-tip="撤销" onclick="globalUndo()">↩</button>
    <button class="icon-btn" data-tip="重做" onclick="globalRedo()">↪</button>
    <select id="fontSizeSel">
      <option value="12px">12</option>
      <option value="14px">14</option>
      <option value="16px" selected>16</option>
      <option value="18px">18</option>
      <option value="20px">20</option>
      <option value="24px">24</option>
    </select>
    <input type="color" class="color-input" id="fontColor" data-tip="文字颜色">
    <input type="color" class="color-input" id="bgColor" data-tip="文字高亮底色">
    <button class="icon-btn" data-tip="加粗" onclick="formatBold()">B</button>
    <button class="icon-btn" data-tip="斜体" onclick="formatItalic()">I</button>
    <button class="icon-btn" data-tip="下划线" onclick="insertUnderline()">U</button>
    <button class="icon-btn" data-tip="删除线" onclick="formatStrikeThrough()">S̶</button>
    <button class="icon-btn" data-tip="居中排版" onclick="insertCenter()">≡</button>
    <button class="icon-btn" data-tip="一级标题" onclick="insertH1()">H1</button>
    <button class="icon-btn" data-tip="二级标题" onclick="insertH2()">H2</button>
    <button class="icon-btn" data-tip="三级标题" onclick="insertH3()">H3</button>
    <button class="icon-btn" data-tip="行内代码" onclick="insertInlineCode()">`</button>
    <button class="icon-btn" data-tip="引用块" onclick="insertQuote()">></button>
    <button class="icon-btn" data-tip="无序列表" onclick="insertUl()">•</button>
    <button class="icon-btn" data-tip="分割线" onclick="splitLine1()">—</button>
    <button class="icon-btn" data-tip="表格" onclick="insertTable()">▦</button>

    <button class="icon-btn" data-tip="本地图片上传" id="localImgBtn">🖼</button>
    <button class="icon-btn" data-tip="批量图床链接" id="batchImgBtn">🔗</button>
    <button class="icon-btn" data-tip="代码块" onclick="insertMdCode()">&lt;/&gt;</button>
    <button class="icon-btn" data-tip="更多工具" onclick="toggleMoreTools()">⋮</button>
    <input type="file" id="hiddenImgFile1" accept="image/*">
    <input type="file" id="hiddenImgFile2" accept="image/*">
  </div>
  <div class="toolbar-more" id="moreToolsPanel">
    <button class="icon-btn" data-tip="插入链接" onclick="insertLink()">[]()</button>
    <button class="icon-btn" data-tip="行内公式" onclick="insertInlineMath()">∑</button>
    <button class="icon-btn" data-tip="复制选中内容" onclick="copySelect()">📋</button>
    <button class="icon-btn" data-tip="段落上移" onclick="moveUp()">↑</button>
    <button class="icon-btn" data-tip="段落下移" onclick="moveDown()">↓</button>
    <button class="icon-btn" data-tip="嵌套引用" onclick="insertFoldQuote()">>></button>
    <button class="icon-btn" data-tip="有序列表" onclick="insertOrderedList()">1.</button>
    <button class="icon-btn" data-tip="任务列表" onclick="insertTaskList()">☐</button>
    <button class="icon-btn" data-tip="插入网络图床图片" onclick="insertImage()">🖼</button>
    <button class="icon-btn" data-tip="空白复选框" onclick="insertEmptyCheckbox()">[]</button>
    <button class="icon-btn" data-tip="已完成复选框" onclick="insertCheckedCheckbox()">[✓]</button>
    <button class="icon-btn" data-tip="固定宽度图片" onclick="insertImgWidth()">img</button>
    <button class="icon-btn" data-tip="块级公式" onclick="insertBlockLatex()">√∑</button>
    <button class="icon-btn" data-tip="取色器" onclick="openColorPicker()">🎨</button>
    <button class="icon-btn" data-tip="长分割线" onclick="splitLine2()">===</button>
    <button class="icon-btn" data-tip="切换MD模式" onclick="switchMode('md')">MD</button>
    <button class="icon-btn" data-tip="切换富文本" onclick="switchMode('rich')">富</button>
  </div>
</div>
<div class="editor-wrap">
  <div class="rich-editor" id="richEditor" contenteditable="true"></div>
  <textarea class="md-editor" id="mdEditor" style="display:none" placeholder="在此书写Markdown内容..."></textarea>
  <div class="md-preview" id="mdPreview" style="display:none"></div>
</div>
</div>
<script>
const CACHE_KEY = "note_temp_data";
const PWD_STORE_KEY = "admin_save_pwd";
let list = [];
let targetNote = null;
const editId = new URLSearchParams(location.search).get("id");
let imgUploadList = [];
let currentEditMode = "rich";
let mdRecordStack = [];
let mdRecordIndex = -1;
let moreToolsOpen = false;
let initViewHeight = window.visualViewport ? window.visualViewport.height : window.innerHeight;
const ADMIN_PASSWORD = "admin123";

// 自动登录+延迟加载笔记，解决DOM未渲染回填空白
function autoLoginCheck(){
  const savedPwd = localStorage.getItem(PWD_STORE_KEY);
  if(savedPwd && savedPwd === ADMIN_PASSWORD){
    document.getElementById("loginWrap").style.display = "none";
    document.getElementById("mainWrap").style.display = "block";
    loadLocalCache();
    window.addEventListener("DOMContentLoaded", ()=>{
      setTimeout(initLoadNote, 100);
    })
  }
}
autoLoginCheck();

function loadLocalCache(){
  const cacheStr = localStorage.getItem(CACHE_KEY);
  if(cacheStr){
    try{
      window.NOTE_DATA = JSON.parse(cacheStr);
      list = window.NOTE_DATA;
    }catch(e){}
  }
}
function saveLocalCache(){
  localStorage.setItem(CACHE_KEY, JSON.stringify(list));
}
function getFullJsText(){
  return `window.NOTE_DATA = ${JSON.stringify(list, null, 2)};`;
}
function getNowTimeStr(){
  const date = new Date();
  const y = date.getFullYear();
  const m = String(date.getMonth()+1).padStart(2,"0");
  const d = String(date.getDate()).padStart(2,"0");
  const h = String(date.getHours()).padStart(2,"0");
  const mi = String(date.getMinutes()).padStart(2,"0");
  const s = String(date.getSeconds()).padStart(2,"0");
  return `${y}-${m}-${d} ${h}:${mi}:${s}`;
}

// DOM缓存
const titleInput = document.querySelector(".title-input");
const typeInput = document.querySelector(".type-input");
const saveNormalBtn = document.getElementById("saveNormalBtn");
const saveTimeBtn = document.getElementById("saveTimeBtn");
const imgFileInput = document.getElementById("imgFileInput");
const hiddenImgFile1 = document.getElementById("hiddenImgFile1");
const hiddenImgFile2 = document.getElementById("hiddenImgFile2");
const copyAllJsonBtn = document.getElementById("copyJsonBtn");
const genCpBtn = document.getElementById("showTemplateBtn");
const codeInsertBtn = document.getElementById("insertCodeBtn");
const batchImgBtn = document.getElementById("batchImgBtn");
const localImgBtn = document.getElementById("localImgBtn");
const richBox = document.getElementById("richEditor");
const mdBox = document.getElementById("mdEditor");
const mdPreviewBox = document.getElementById("mdPreview");
const fontSizeSelect = document.getElementById("fontSizeSel");
const fontColorInput = document.getElementById("fontColor");
const bgColorInput = document.getElementById("bgColor");
const richModeBtn = document.getElementById("modeRich");
const mdModeBtn = document.getElementById("modeMd");
const moreToolsPanel = document.getElementById("moreToolsPanel");
const exportBackupBtn = document.getElementById("exportFullBackup");
const importBackupBtn = document.getElementById("importBackup");
const backupFileInput = document.getElementById("backupFileInput");

function toggleMoreTools(){
  moreToolsOpen = !moreToolsOpen;
  moreToolsPanel.classList.toggle("show", moreToolsOpen);
}
function saveMdRecord(){
  mdRecordStack.splice(mdRecordIndex+1);
  mdRecordStack.push(mdBox.value);
  mdRecordIndex = mdRecordStack.length - 1;
}
function mdUndo(){
  if(mdRecordIndex <= 0) return;
  mdRecordIndex--;
  mdBox.value = mdRecordStack[mdRecordIndex];
  renderMdPreview();
}
function mdRedo(){
  if(mdRecordIndex >= mdRecordStack.length - 1) return;
  mdRecordIndex++;
  mdBox.value = mdRecordStack[mdRecordIndex];
  renderMdPreview();
}
function globalUndo(){
  if(currentEditMode === "rich") document.execCommand("undo");
  else mdUndo();
}
function globalRedo(){
  if(currentEditMode === "rich") document.execCommand("redo");
  else mdRedo();
}

function viewportResizeHandle(){
  const curH = window.visualViewport ? window.visualViewport.height : window.innerHeight;
  if(curH < initViewHeight - 100) document.body.classList.add("keyboard-opened");
  else document.body.classList.remove("keyboard-opened");
}
if(window.visualViewport) window.visualViewport.addEventListener("resize", viewportResizeHandle);
else window.addEventListener("resize", viewportResizeHandle);

// 修复切换函数：表格双向转换、清理多余换行、不重复增行
function switchMode(mode){
  currentEditMode = mode;
  richModeBtn.classList.toggle("active", mode === "rich");
  mdModeBtn.classList.toggle("active", mode === "md");
  if(mode === "rich"){
    let mdText = mdBox.value;
    let parseHtml = mdText.replace(/(^|\n)(\|.+\|\n)(\|----.+\|\n)+(\|.+\|)(\n|$)/g, (_, pre, hRow, sepRow, cRow, suf)=>{
      const block = `${hRow}${sepRow}${cRow}`.trim();
      const rows = block.split("\n");
      let tableDom = `<table style="width:100%;border-collapse:collapse;margin:8px 0;">`;
      rows.forEach((row, idx)=>{
        const cells = row.split("|").filter(s=>s.trim() !== "");
        tableDom += "<tr>";
        cells.forEach(txt=>{
          const tag = idx === 0 ? "th" : "td";
          tableDom += `<${tag} style="border:1px solid #999;padding:6px 8px;">${txt.trim()}</${tag}>`;
        });
        tableDom += "</tr>";
      });
      tableDom += "</table>";
      return `${pre}${tableDom}${suf}`;
    });
    richBox.innerHTML = mdToHtml(parseHtml);
    richBox.style.display = "block";
    mdBox.style.display = "none";
    mdPreviewBox.style.display = "none";
    checkFormatActive();
  }else{
    let htmlText = richBox.innerHTML;
    let parseMd = htmlText.replace(/<table[\s\S]*?<\/table>/g, tab=>{
      const trList = tab.match(/<tr[\s\S]*?<\/tr>/g) || [];
      let mdTable = "";
      trList.forEach((tr, rowIdx)=>{
        const cellList = tr.match(/<t[hd][\s\S]*?<\/t[hd]>/g) || [];
        let line = "";
        cellList.forEach(cell=>{
          const text = cell.replace(/<\/?t[hd].*?>/g,"").trim();
          line += `|${text}`;
        });
        line += "|\n";
        mdTable += line;
        if(rowIdx === 0){
          let sepLine = "";
          cellList.forEach(()=> sepLine += "|----");
          sepLine += "|\n";
          mdTable += sepLine;
        }
      });
      return "\n" + mdTable.trim() + "\n";
    });
    parseMd = parseMd.replace(/\n{3,}/g,"\n\n");
    mdBox.value = htmlToMd(parseMd);
    saveMdRecord();
    renderMdPreview();
    richBox.style.display = "none";
    mdBox.style.display = "block";
    mdPreviewBox.style.display = "block";
  }
}

// 优化md转html
function mdToHtml(mdStr){
  return mdStr
    .replace(/```([\s\S]*?)```/g, '<pre style="background:#f5f5f5;padding:10px;border-radius:6px;white-space:pre-wrap;"><code>$1</code></pre>')
    .replace(/<u>(.*?)<\/u>/g, '<u>$1</u>')
    .replace(/<p style="text-align:center">(.*?)<\/p>/g, '<p style="text-align:center">$1</p>')
    .replace(/^### (.*)$/gm, '<h3>$1</h3>')
    .replace(/^## (.*)$/gm, '<h2>$1</h2>')
    .replace(/^# (.*)$/gm, '<h1>$1</h1>')
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.*?)\*/g, '<em>$1</em>')
    .replace(/~~(.*?)~~/g, '<s>$1</s>')
    .replace(/^\- (.*)$/gm, '<li>$1</li>')
    .replace(/!\[(.*?)\]\((https?:\/\/[^\s)]+)\)\{width=(\d+)\}/g, '<img src="$2" alt="$1" style="max-width:100%;margin:8px 0;width:$3px;">')
    .replace(/!\[(.*?)\]\((https?:\/\/[^\s)]+)\)/g, '<img src="$2" alt="$1" style="max-width:100%;margin:8px 0;">')
    .replace(/\n/g, '<br>');
}
// 优化html转md：保留表格、u、居中标签，不粗暴删除
function htmlToMd(htmlStr){
  let text = htmlStr
    .replace(/<pre style="background:#f5f5f5;padding:10px;border-radius:6px;white-space:pre-wrap;"><code>([\s\S]*?)<\/code><\/pre>/g, '```\n$1\n```')
    .replace(/<h1>(.*?)<\/h1>/g, '# $1')
    .replace(/<h2>(.*?)<\/h2>/g, '## $1')
    .replace(/<h3>(.*?)<\/h3>/g, '### $1')
    .replace(/<strong>(.*?)<\/strong>/g, '**$1**')
    .replace(/<em>(.*?)<\/em>/g, '*$1*')
    .replace(/<s>(.*?)<\/s>/g, '~~$1~~')
    .replace(/<li>(.*?)<\/li>/g, '- $1')
    .replace(/<img.*?width="(\d+)px".*?src="(.*?)".*?alt="(.*?)".*?>/g, '![$3]($2){width=$1}')
    .replace(/<img.*?src="(.*?)".*?alt="(.*?)".*?>/g, '![$2]($1)')
    .replace(/<br>/g, '\n');
  // 仅过滤无关标签，保留table/tr/th/td/u/居中p
  text = text.replace(/<(?!p style="text-align:center"|u|table|tr|th|td)[^>]+>/g, '');
  return text;
}
function renderMdPreview(){
  mdPreviewBox.innerHTML = mdToHtml(mdBox.value);
}
mdBox.addEventListener("input", ()=>{
  saveMdRecord();
  renderMdPreview();
});

// 格式按钮高亮检测（修复H2/H3错乱）
function checkFormatActive(){
  document.querySelectorAll(".icon-btn").forEach(btn=>btn.classList.remove("active-format"));
  if(currentEditMode !== "rich") return;
  const isBold = document.queryCommandState("bold");
  const isItalic = document.queryCommandState("italic");
  const isUnder = document.queryCommandState("underline");
  const isStrike = document.queryCommandState("strikeThrough");
  if(isBold) document.querySelector('[onclick="formatBold()"]').classList.add("active-format");
  if(isItalic) document.querySelector('[onclick="formatItalic()"]').classList.add("active-format");
  if(isUnder) document.querySelector('[onclick="insertUnderline()"]').classList.add("active-format");
  if(isStrike) document.querySelector('[onclick="formatStrikeThrough()"]').classList.add("active-format");

  const sel = window.getSelection();
  const rng = sel.getRangeAt(0);
  let tagEl = rng.commonAncestorContainer;
  let curTag = "";
  while(tagEl.nodeType === 1){
    const tag = tagEl.tagName.toLowerCase();
    if(["h1","h2","h3"].includes(tag)){
      curTag = tag;
      break;
    }
    tagEl = tagEl.parentNode;
    if(tagEl === richBox) break;
  }
  if(curTag === "h1") document.querySelector('[onclick="insertH1()"]').classList.add("active-format");
  if(curTag === "h2") document.querySelector('[onclick="insertH2()"]').classList.add("active-format");
  if(curTag === "h3") document.querySelector('[onclick="insertH3()"]').classList.add("active-format");

  let curBlock = rng.commonAncestorContainer;
    while(curBlock.nodeType !== 1 || !["P","H1","H2","H3","DIV"].includes(curBlock.tagName)){
    curBlock = curBlock.parentNode;
    if(!curBlock || curBlock === richBox) break;
  }
  if(curBlock && curBlock.style.textAlign === "center"){
    document.querySelector('[onclick="insertCenter()"]').classList.add("active-format");
  }
}
richBox.addEventListener("selectionchange", checkFormatActive);
richBox.addEventListener("input", checkFormatActive);

// 登录校验
function checkPwd(){
  const inputPwd = document.getElementById("pwdInput").value.trim();
  if(inputPwd !== ADMIN_PASSWORD){
    alert("密码错误，无法进入编辑器");
    return;
  }
  localStorage.setItem(PWD_STORE_KEY, inputPwd);
  document.getElementById("loginWrap").style.display = "none";
  document.getElementById("mainWrap").style.display = "block";
  loadLocalCache();
  setTimeout(initLoadNote,100);
}

// 【核心修复】初始化加载笔记，回填不丢失、不破坏按钮逻辑
function initLoadNote(){
  list = window.NOTE_DATA || [];
  if(!editId) return;
  const target = list.find(item=>item.id === Number(editId));
  if(!target) return;
  targetNote = target;
  titleInput.value = target.title;
  typeInput.value = target.type;
  richBox.innerHTML = target.content || "";
  // 转换md并清理多余换行，不新增变量冲突
  mdBox.value = htmlToMd(target.content || "").replace(/\n{3,}/g,"\n\n");
  saveMdRecord();
  renderMdPreview();
  checkFormatActive();
}
function getLineStart(text, pos){
  let i = pos;
  while(i > 0 && text[i-1] !== "\n") i--;
  return i;
}

// ========== 全部格式化函数（修复纯文本光标定位）==========
//加粗
function formatBold(){
  if(currentEditMode === "rich"){
    richBox.focus();
    document.execCommand("bold", false, null);
    checkFormatActive();
  }else{
    const tpl = "****";
    mdBox.value += tpl;
    saveMdRecord();
    renderMdPreview();
    const pos = mdBox.value.length - 2;
    mdBox.selectionStart = pos;
    mdBox.selectionEnd = pos;
    //回车自动续写加粗
    mdBox.onkeydown = function(e){
      if(e.key === "Enter"){
        const cur = mdBox.selectionStart;
        const txt = mdBox.value;
        const close = txt.indexOf("**", cur);
        if(close > cur){
          e.preventDefault();
          mdBox.selectionStart = close + 2;
          mdBox.selectionEnd = close + 2;
          mdBox.value = txt.slice(0, close+2) + "\n" + txt.slice(close+2);
          saveMdRecord();
          renderMdPreview();
        }
      }
    }
  }
}
//斜体
function formatItalic(){
  if(currentEditMode === "rich"){
    richBox.focus();
    document.execCommand("italic", false, null);
    checkFormatActive();
  }else{
    const tpl = "*";
    mdBox.value += tpl;
    saveMdRecord();
    renderMdPreview();
    const pos = mdBox.value.length - 1;
    mdBox.selectionStart = pos;
    mdBox.selectionEnd = pos;
    mdBox.onkeydown = function(e){
      if(e.key === "Enter"){
        const cur = mdBox.selectionStart;
        const txt = mdBox.value;
        const close = txt.indexOf("*", cur);
        if(close > cur){
          e.preventDefault();
          mdBox.selectionStart = close + 1;
          mdBox.selectionEnd = close + 1;
          mdBox.value = txt.slice(0, close+1) + "\n" + txt.slice(close+1);
          saveMdRecord();
          renderMdPreview();
        }
      }
    }
  }
}
