//下划线
function insertUnderline(){
  if(currentEditMode === "rich"){
    richBox.focus();
    document.execCommand("underline", false, null);
    checkFormatActive();
  }else{
    const tpl = "<u></u>";
    mdBox.value += tpl;
    saveMdRecord();
    renderMdPreview();
    const pos = mdBox.value.length - 4;
    mdBox.selectionStart = pos;
    mdBox.selectionEnd = pos;
    mdBox.onkeydown = function(e){
      if(e.key === "Enter"){
        const curPos = mdBox.selectionStart;
        const fullText = mdBox.value;
        const closeTagPos = fullText.indexOf("</u>", curPos);
        if(closeTagPos > curPos){
          e.preventDefault();
          mdBox.selectionStart = closeTagPos + 4;
          mdBox.selectionEnd = closeTagPos + 4;
          mdBox.value = fullText.slice(0, closeTagPos + 4) + "\n" + fullText.slice(closeTagPos + 4);
          saveMdRecord();
          renderMdPreview();
        }
      }
    }
  }
}
