function insertImage(){
  const mask = document.createElement("div");
  mask.className = "modal-mask";
  const box = document.createElement("div");
  box.className = "modal-box";
  const winHtml = `
    <h2 style="margin:0 0 18px 0;font-weight:normal;color:#111;">插入Markdown图片</h2>
    <div style="font-size:15px;color:#666;line-height:1.6;margin-bottom:26px;">
      请在下面输入您要插入的网络图片链接。<br>
      或者您可以点击左下角的「本地图片」来选取本地图片并自动获取该图片的本地链接。
    </div>
    <div style="margin-bottom:20px;">
      <input id="imgLink" class="modal-input" placeholder="图片链接">
    </div>
    <div style="margin-bottom:34px;">
      <input id="imgDesc" class="modal-input" placeholder="图片描述（可不填）">
    </div>
    <div style="display:flex;justify-content:space-between;align-items:center;">
      <button id="localImgTrigger1" class="modal-btn">本地图片</button>
      <div style="display:flex;gap:40px;">
        <button id="cancelImgWin" class="modal-btn">取消</button>
        <button id="confirmImgWin" class="modal-btn">好的</button>
      </div>
    </div>
  `;
  box.innerHTML = winHtml;
  mask.appendChild(box);
  document.body.appendChild(mask);
  const linkInput = box.querySelector("#imgLink");
  const descInput = box.querySelector("#imgDesc");
  const localBtn = box.querySelector("#localImgTrigger1");
  const cancelBtn = box.querySelector("#cancelImgWin");
  const confirmBtn = box.querySelector("#confirmImgWin");
  const fileInput = hiddenImgFile1;

  function closeModal(){ mask.remove(); }
  mask.onclick = e => e.target === mask && closeModal();
  cancelBtn.onclick = closeModal;
  localBtn.onclick = ()=> fileInput.click();

  fileInput.onchange = function(e){
const file = e.target.files[0];
if(!file) return closeModal();

const originRealName = file.name;
let showName = originRealName;
const badNameReg = /^(image|img)\.(jpg|png|webp|jpeg)$/i;
if(!showName || showName.length < 4 || badNameReg.test(showName)){
  const ext = file.type.split('/')[1] || 'jpg';
  showName = `IMG_${Date.now()}.${ext}`;
}
const safeName = showName;

insertLocalImgTag(safeName);
let path = "~/storage/dcim/Camera";
if(/^Screenshot/.test(originRealName)) path = "~/storage/Pictures/Screenshots";
if(/wx|wechat/.test(originRealName.toLowerCase())) path = "~/storage/Download";

imgUploadList.push({
  name:safeName,
  src:`${path}/${originRealName}`
});
closeModal();
};


  confirmBtn.onclick = function(){
    const url = linkInput.value.trim();
    const altText = descInput.value.trim();
    if(!url){
      alert("请填写图片链接地址");
      return;
    }
    if(currentEditMode === "rich"){
      const imgHtml = `<img loading="lazy" src="${url}" alt="${altText}" style="max-width:100%;margin:8px 0;"><br><br>`;
      document.execCommand("insertHTML",false,imgHtml);
      richBox.focus();
    }else{
      const alt = altText || "配图";
      mdBox.value += `![${alt}](${url})\n\n`;
      saveMdRecord();
      renderMdPreview();
    }
    closeModal();
  };
  setTimeout(()=>linkInput.focus(),60);
}

//固定宽度图片弹窗
function insertImgWidth(){
  const mask = document.createElement("div");
  mask.className = "modal-mask";
  const box = document.createElement("div");
  box.className = "modal-box";
  const winHtml = `
    <h2 style="margin:0 0 18px 0;font-weight:normal;color:#111;">插入Markdown图片</h2>
    <div style="font-size:15px;color:#666;line-height:1.6;margin-bottom:26px;">
      请在下面输入您要插入的网络图片链接。<br>
      或者您可以点击左下角的「本地图片」来选取本地图片并自动获取该图片的本地链接。
    </div>
    <div style="margin-bottom:20px;">
      <input id="imgLinkW" class="modal-input" placeholder="图片链接">
    </div>
    <div style="display:flex;gap:16px;margin-bottom:34px;">
      <div style="flex:1;">
        <input id="imgDescW" class="modal-input" placeholder="图片描述（可不填...）">
      </div>
      <div style="flex:0.45;">
        <input id="imgWidthW" class="modal-input" placeholder="宽度" type="number">
      </div>
    </div>
    <div style="display:flex;justify-content:space-between;align-items:center;">
      <button id="localImgTrigger2" class="modal-btn">本地图片</button>
      <div style="display:flex;gap:40px;">
        <button id="cancelImgWinW" class="modal-btn">取消</button>
        <button id="confirmImgWinW" class="modal-btn">好的</button>
      </div>
    </div>
  `;
  box.innerHTML = winHtml;
  mask.appendChild(box);
  document.body.appendChild(mask);
  const linkInput = box.querySelector("#imgLinkW");
  const descInput = box.querySelector("#imgDescW");
  const widthInput = box.querySelector("#imgWidthW");
  const localBtn = box.querySelector("#localImgTrigger2");
  const cancelBtn = box.querySelector("#cancelImgWinW");
  const confirmBtn = box.querySelector("#confirmImgWinW");
  const fileInput = hiddenImgFile2;

  function closeModal(){ mask.remove(); }
  mask.onclick = e => e.target === mask && closeModal();
  cancelBtn.onclick = closeModal;
  localBtn.onclick = ()=> fileInput.click();

  fileInput.onchange = function(e){
const file = e.target.files[0];
if(!file) return closeModal();

const originRealName = file.name;
let showName = originRealName;
const badNameReg = /^(image|img)\.(jpg|png|webp|jpeg)$/i;
if(!showName || showName.length < 4 || badNameReg.test(showName)){
  const ext = file.type.split('/')[1] || 'jpg';
  showName = `IMG_${Date.now()}.${ext}`;
}
const safeName = showName;

insertLocalImgTag(safeName);
let path = "~/storage/dcim/Camera";
if(/^Screenshot/.test(originRealName)) path = "~/storage/Pictures/Screenshots";
if(/wx|wechat/.test(originRealName.toLowerCase())) path = "~/storage/Download";

imgUploadList.push({
  name:safeName,
  src:`${path}/${originRealName}`
});
closeModal();
};

  confirmBtn.onclick = function(){
    const url = linkInput.value.trim();
    const altText = descInput.value.trim();
    const wNum = widthInput.value.trim();
    if(!url){
      alert("请填写图片链接地址");
      return;
    }
    if(currentEditMode === "rich"){
      let wStyle = "";
      if(wNum && Number(wNum) > 0) wStyle = `width:${wNum}px;`;
      const imgHtml = `<img loading="lazy" src="${url}" alt="${altText}" style="max-width:100%;margin:8px 0;${wStyle}"><br><br>`;
      document.execCommand("insertHTML",false,imgHtml);
      richBox.focus();
    }else{
      const alt = altText || "配图";
      let mdImg = `![${alt}](${url})`;
      if(wNum && Number(wNum) > 0) mdImg += `{width=${wNum}}`;
      mdBox.value += `${mdImg}\n\n`;
      saveMdRecord();
      renderMdPreview();
    }
    closeModal();
  };
  setTimeout(()=>linkInput.focus(),60);
}

//本地图片插入通用方法
function insertLocalImgTag(fileName){
  const imgHtml = `<img loading="lazy" src="/notes/images/${fileName}" alt="配图" style="max-width:100%;margin:8px 0;"><br><br>`;
  if(currentEditMode === "rich"){
    document.execCommand("insertHTML",false,imgHtml);
  }else{
    mdBox.value += `![配图](/notes/images/${fileName})\n\n`;
    saveMdRecord();
    renderMdPreview();
  }
}
// 本地图片上传按钮（插入不改名版）
localImgBtn.onclick = () => imgFileInput.click();

imgFileInput.onchange = function(e){
  const files = Array.from(e.target.files);
  if(files.length === 0) return;

  imgUploadList = [];

  files.forEach((file) => {
    // ✅ 永远用浏览器给的名字，一个字不改
    const fileName = file.name;

    // ✅ 插入编辑器（data.js / 预览都用这个）
    insertLocalImgTag(fileName);

    // ✅ 来源识别
    let path = "~/storage/dcim/Camera";
    if(/^Screenshot/.test(fileName)) {
      path = "~/storage/Pictures/Screenshots";
    } else if(/wx|wechat/i.test(fileName)) {
      path = "~/storage/Download";
    }

    // ✅ 记录（用于生成 cp 命令）
    imgUploadList.push({
      name: fileName,
      src: `${path}/${fileName}`
    });
  });

  imgFileInput.value = "";
  alert(`已插入${files.length}张图片，生成复制命令时会校验文件名`);
};

    }

    // ✅ 插入编辑器（展示 + data.js）
    insertLocalImgTag(finalName);

    // ✅ 来源识别（用 finalName）
    let path = "~/storage/dcim/Camera";
    if(/^Screenshot/.test(finalName)) {
      path = "~/storage/Pictures/Screenshots";
    } else if(/wx|wechat/i.test(finalName)) {
      path = "~/storage/Download";
    }

    // ✅ cp 路径 = finalName（关键修正）
    imgUploadList.push({
      name: finalName,
      src: `${path}/${finalName}`
    });
  });

  imgFileInput.value = "";
  alert(`已记录${files.length}张本地图片，可生成复制命令`);
};


//批量图床链接
batchImgBtn.onclick = function(){
  const multiUrl = prompt("批量粘贴图床链接，一行一张：");
  if(!multiUrl || multiUrl.trim() === "") return;
  const urlArr = multiUrl.split(/\r?\n/).map(item=>item.trim()).filter(u=>u.startsWith("http"));
  if(urlArr.length === 0){
    alert("未识别有效图片链接");
    return;
  }
  urlArr.forEach(url=>{
    if(currentEditMode === "rich"){
      const imgHtml = `<img loading="lazy" src="${url}" alt="配图" style="max-width:100%;margin:8px 0;"><br><br>`;
      document.execCommand("insertHTML",false,imgHtml);
    }else{
      mdBox.value += `![配图](${url})\n\n`;
    }
  });
  if(currentEditMode === "md"){
    saveMdRecord();
    renderMdPreview();
  }
  alert(`成功插入${urlArr.length}张网络图`);
};
//同步表单数据到笔记数组
function syncFormToNoteList(){
  const title = titleInput.value.trim();
  const type = typeInput.value.trim();
  let content = "";
  if(currentEditMode === "rich") content = richBox.innerHTML.trim();
  else content = mdToHtml(mdBox.value);
  const nowTime = getNowTimeStr();
  if(targetNote){
    const idx = list.findIndex(item=>item.id === targetNote.id);
    list[idx].title = title;
    list[idx].type = type;
    list[idx].content = content;
    list[idx].date = nowTime;
  }else{
    const newNote = {
      id: Date.now(),
      title,
      type,
      content,
      date: nowTime,
      _isTempNew: true
    };
    list.push(newNote);
  }
  saveLocalCache();
}
//一键复制完整data.js
copyAllJsonBtn.onclick = async function(){
  syncFormToNoteList();
  const text = getFullJsText();
  try{
    await navigator.clipboard.writeText(text);
  }catch{
    const tempTextarea = document.createElement("textarea");
    tempTextarea.value = text;
    document.body.appendChild(tempTextarea);
    tempTextarea.select();
    document.execCommand("copy");
    document.body.removeChild(tempTextarea);
  }
  alert("完整data.js已复制，仅粘贴nano，禁止粘贴终端命令");
};
//生成图片复制脚本
genCpBtn.onclick = async function(){
  // ✅ 新增：生成前先校验文件名
  let warnList = [];
  imgUploadList.forEach(item => {
    if(
      !item.name ||
      item.name.startsWith("blob:") ||
      /^(image|img)\.(jpg|png|webp|jpeg)$/i.test(item.name)
    ){
      warnList.push(item.name || "(空文件名)");
    }
  });

  // ✅ 有可疑文件名 → 拦截，不生成命令
  if(warnList.length > 0){
    alert(
      "⚠️ 以下文件名可能不是真实文件名，cp 可能失败：\n\n" +
      warnList.join("\n") +
      "\n\n请确认手机相册中存在这些文件，或修改后再执行命令。"
    );
    return; // ✅ 直接返回，不复制命令
  }

  // ✅ 文件名都正常，才执行你原来的逻辑
  let cpText = "# 仅复制页面选中图片，不会读取手机全部图片\n";
  imgUploadList.forEach(item=>{
    cpText += `cp -v ${item.src} images/\n`;
  });
  const gitCmd = `cd ~/storage/shared/notes\nmkdir -p images\n${cpText}\nrm -f data.js && nano data.js && git add . && git diff --cached --quiet || (git commit -m "更新笔记 ${getNowTimeStr()}" && git push origin main)`;
  try{
    await navigator.clipboard.writeText(gitCmd);
  }catch{
    const tempTextarea = document.createElement("textarea");
    tempTextarea.value = gitCmd;
    document.body.appendChild(tempTextarea);
    tempTextarea.select();
    document.execCommand("copy");
    document.body.removeChild(tempTextarea);
  }
  alert("图片复制脚本已复制");
};

//下载data.js文件
function downloadDataJs(isTimeStamp){
  syncFormToNoteList();
  const jsText = getFullJsText();
   const blob = new Blob([jsText], {type:"application/javascript"});
  const name = isTimeStamp ? `data_${Date.now()}.js` : "data.js";
  const a = document.createElement("a");
  a.href = URL.createObjectURL(blob);
  a.download = name;
  a.click();
  URL.revokeObjectURL(a.href);
}

saveNormalBtn.onclick = ()=>downloadDataJs(false);
saveTimeBtn.onclick = ()=>downloadDataJs(true);

// 备份导出
exportBackupBtn.onclick = function(){
  syncFormToNoteList();
  const blob = new Blob([JSON.stringify(list,null,2)],{type:"application/json"});
  const a = document.createElement("a");
  a.href = URL.createObjectURL(blob);
  a.download = `notes_backup_${Date.now()}.json`;
  a.click();
  URL.revokeObjectURL(a.href);
  alert("完整笔记JSON备份已导出");
}

// 备份导入
backupFileInput.onchange = function(e){
  const file = e.target.files[0];
  if(!file) return;
  const reader = new FileReader();
  reader.onload = ev=>{
    try{
      list = JSON.parse(ev.target.result);
      saveLocalCache();
      alert("备份导入成功，刷新页面生效");
    }catch(err){
      alert("文件格式错误，请导入标准json备份");
    }
  };
  reader.readAsText(file);
};

//字号颜色同步
fontSizeSel.onchange = function(){
  if(currentEditMode !== "rich") return;
  richBox.focus();
  document.execCommand("fontSize", false, "7");
  document.execCommand("styleWithCSS",false,true);
  const span = window.getSelection().anchorNode.parentNode;
  if(span.tagName === "SPAN") span.style.fontSize = fontSizeSel.value;
};
fontColorInput.oninput = function(){
  if(currentEditMode !== "rich") return;
  richBox.focus();
  document.execCommand("foreColor", false, fontColorInput.value);
};
bgColorInput.oninput = function(){
  if(currentEditMode !== "rich") return;
  richBox.focus();
  document.execCommand("backColor", false, bgColorInput.value);
};

//回车自动闭合格式
richBox.addEventListener("keydown",e=>{
  if(e.key === "Enter"){
    setTimeout(checkFormatActive,10);
  }
});

//页面销毁清理
window.addEventListener("beforeunload",()=>{
  syncFormToNoteList();
});
</script>
</body>
</html>

