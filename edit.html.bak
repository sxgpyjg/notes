    renderMdPreview();
    const targetPos = mdBox.value.length - 4;
    mdBox.selectionStart = targetPos;
    mdBox.selectionEnd = targetPos;
  }
}
function insertLink(){
  const tpl = "[](链接地址)";
  if(currentEditMode === "rich"){
    document.execCommand("insertHTML",false,'<a href="">文字</a>');
    const sel = window.getSelection();
    const range = sel.getRangeAt(0);
    range.setStart(range.startContainer, range.startOffset - 4);
    range.collapse(true);
    sel.removeAllRanges();
    sel.addRange(range);
    richBox.focus();
  }else{
    mdBox.value += tpl;
    saveMdRecord();
    renderMdPreview();
    const pos = mdBox.value.length - "](链接地址)".length;
    mdBox.selectionStart = pos;
    mdBox.selectionEnd = pos;
  }
}
function insertInlineCode(){
  const tpl = "``";
  if(currentEditMode === "rich"){
    document.execCommand("insertText",false,tpl);
    const sel = window.getSelection();
    const range = sel.getRangeAt(0);
    range.setStart(range.startContainer, range.startOffset - 1);
    range.collapse(true);
    sel.removeAllRanges();
    sel.addRange(range);
    richBox.focus();
  }else{
    mdBox.value += tpl;
    saveMdRecord();
    renderMdPreview();
    const pos = mdBox.value.length - 1;
    mdBox.selectionStart = pos;
    mdBox.selectionEnd = pos;
  }
}
function insertCenter(){
  if(currentEditMode === "rich"){
    richBox.focus();
    const sel = window.getSelection();
    const range = sel.getRangeAt(0);
    let block = range.commonAncestorContainer;
    while(block.nodeType !== 1 || !["P","H1","H2","H3","DIV"].includes(block.tagName)){
      block = block.parentNode;
      if(!block || block === richBox) break;
    }
    let isCenter = block && block.style.textAlign === "center";
    if(isCenter){
      document.execCommand("justifyLeft", false, null);
      block.style.textAlign = "";
    }else{
      document.execCommand("justifyCenter", false, null);
    }
    checkFormatActive();
  }else{
    const tpl = '<p style="text-align:center"></p>';
    mdBox.value += tpl;
    saveMdRecord();
    renderMdPreview();
    const pos = mdBox.value.length - 4;
    mdBox.selectionStart = pos;
    mdBox.selectionEnd = pos;
  }
}
function insertH1(){
  if(currentEditMode === "rich"){
    richBox.focus();
    const sel = window.getSelection();
    const rng = sel.getRangeAt(0);
