<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>笔记目录</title>
<style>
*{
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: system-ui, -apple-system, sans-serif;
}
body{
  background: #ffffff;
  padding: 0 4px;
  max-width: 1280px;
  margin: 0 auto;
}
header{
  margin-bottom: 12px;
  padding: 8px 6px;
  border-bottom: 1px solid #e4e7f3;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
}
.header-right-group{
  display: flex;
  gap:6px;
  align-items:center;
}
h1#secretTrigger{
  font-size: 20px;
  color: #1d2133;
  font-weight: 600;
  cursor: pointer;
  user-select: none;
  -webkit-user-select: none;
  touch-action: none;
}
#fullPageBtn{
  width:68px;height:68px;
  border:none;background:transparent;
  display:flex;align-items:center;justify-content:center;
  -webkit-tap-highlight-color:transparent;
  transition:all 0.12s;
  padding:0;
  cursor: pointer;
}
#fullPageBtn:active{transform:scale(0.92);}
#fullPageBtn svg{
  width:46px;height:46px;
}
#fullPageBtn path{
  fill:none;
  stroke:#9ca3af;
  stroke-width:2;
  stroke-linecap:round;
  stroke-linejoin:round;
}
.admin-logout-btn{
  padding:4px 8px;
  border:none;
  border-radius:6px;
  background:#e0e7ff;
  color:#334155;
  font-size:12px;
  cursor: pointer;
  display:none;
}
.empty-tip{
  text-align: center;
  padding: 80px 4px;
  color: #888;
  font-size: 16px;
}
.note-list{
  display: flex;
  flex-direction: column;
  gap: 0;
}
.note-card{
  background: #fff;
  padding: 12px;
  cursor: pointer;
  display: flex;
  gap: 14px;
  border-radius: 16px;
  align-items: center;
  user-select: none;
  -webkit-user-select: none;
  transition: background 0.15s;
}
.note-card:hover{
  background: #f0f4ff;
}
.card-img-box{
  width: 100px;
  height: 75px;
  flex-shrink: 0;
  border-radius: 7px;
  overflow: hidden;
  background: #f2f5fc;
}
.card-img-box img{
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.card-right-wrap{
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding: 3px 0;
}
.card-head{
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 8px;
}
.card-title{
  font-size: 15px;
  font-weight: 600;
  color: #111827;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.tag-group {
  display: flex;
  gap: 4px;
  flex-wrap: wrap;
  max-width: 50%;
}
.tag-multi {
  font-size: 10px;
  padding: 2px 6px;
  border-radius: 99px;
  background: #e8eaff;
  color: #3950cc;
  flex-shrink: 0;
  max-width: 80px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  border: 1px solid #3950cc;  /* 添加边框 */
}
.tag-private {
  font-size: 10px;
  padding: 2px 6px;
  border-radius: 99px;
  background: #fef3c7;
  color: #b45309;
  flex-shrink: 0;
  font-weight: 600;
}
.card-date{
  font-size: 10px;
  color: #6b7280;
  margin-top: -2px;
}
.card-preview{
  font-size: 13px;
  color: #6b7280;
  line-height: 1.35;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
/* 新增：预览内表格边框样式 */
.card-preview table {
  border-collapse: collapse;
  width: 100%;
  margin: 4px 0;
  font-size: inherit;
}
.card-preview table td,
.card-preview table th {
  border: 1px solid #d1d5db;
  padding: 4px 6px;
  vertical-align: middle;
}
.card-preview table th {
  background-color: #f9fafb;
}

.filter-collapse{
  border:1px solid #dbeafe;
  border-radius:12px;
  margin:0 2px 16px;
  overflow:hidden;
}
.filter-header{
  padding:12px 16px;
  background:#eff6ff;
  cursor:pointer;
  display:flex;
  justify-content:space-between;
  align-items:center;
  font-weight:500;
  font-size:15px;
  touch-action: manipulation;
}
.filter-body{
  padding:12px;
  display:none;
  background:#fff;
}
.filter-body.show{
  display:block;
}
.arrow{
  transition:transform 0.24s ease;
  font-size:14px;
}
.arrow.rotate{
  transform:rotate(180deg);
}
.filter-btn{
  padding:6px 11px;
  border:none;
  border-radius:8px;
  margin:4px;
  background:#e0e7ff;
  color:#334155;
  font-size:13px;
  transition:0.2s;
  cursor: pointer;
}
.filter-btn.active{
  background:#6366F1;
  color:#fff;
}
</style>
</head>
<body>

<header>
  <h1 id="secretTrigger">笔记目录</h1>
  <div class="header-right-group">
    <button class="admin-logout-btn" id="logoutBtn">退出登录</button>
    <button id="fullPageBtn">
      <svg viewBox="0 0 24 24" id="fullSvg">
        <path d="M10 7 H7 V10"/>
        <path d="M14 7 H17 V10"/>
        <path d="M14 17 H17 V14"/>
        <path d="M10 17 H7 V14"/>
      </svg>
    </button>
  </div>
</header>

<div class="filter-collapse">
  <div class="filter-header" id="filterHeader">
    <span>笔记分类筛选</span>
    <span class="arrow" id="filterArrow">▼</span>
  </div>
  <div class="filter-body" id="filterBody">
    <button class="filter-btn active" onclick="filterByTag(null)">全部</button>
  </div>
</div>

<div class="note-list" id="noteWrap"></div>

<script src="./data.js?v=1"></script>
<script>
/* ========== 基础配置 ========== */
const LONG_PRESS_TIME = 600;
const MOVE_THRESHOLD = 8;
const ADMIN_PWD = "admin123";
const LOGIN_EXPIRE_HOUR = 8;
const PWD_STORE_KEY = "admin_save_pwd";
const LOGIN_EXPIRE_KEY = "admin_login_expire";
const LOCAL_NOTE_KEY = "notes";
let filterJustLongPressed = false;
let dataList = [];
let currentFilter = "";
let allTypes = new Set();
let currentFilterTag = null;

/* ========== DOM ========== */
const wrap = document.getElementById('noteWrap');
const logoutBtn = document.getElementById('logoutBtn');
const fullBtn = document.getElementById('fullPageBtn');
const fullSvg = document.getElementById('fullSvg');
const filterHeader = document.getElementById('filterHeader');
const filterBody = document.getElementById('filterBody');
const filterArrow = document.getElementById('filterArrow');

/* ========== 工具 ========== */
function isAdminLoggedIn(){
  const pwd = localStorage.getItem(PWD_STORE_KEY);
  const exp = Number(localStorage.getItem(LOGIN_EXPIRE_KEY)) || 0;
  return pwd === ADMIN_PWD && Date.now() < exp;
}

function saveLoginState(){
  localStorage.setItem(PWD_STORE_KEY, ADMIN_PWD);
  localStorage.setItem(LOGIN_EXPIRE_KEY, Date.now() + LOGIN_EXPIRE_HOUR * 3600 * 1000);
  logoutBtn.style.display = 'inline-block';
}

function openAdminPage(){
  if(isAdminLoggedIn()){
    location.href = 'admin-list.html';
    return;
  }
  const pwd = prompt('请输入管理员密码：');
  if(pwd === ADMIN_PWD){
    saveLoginState();
    location.href = 'admin-list.html';
  }else if(pwd !== null){
    alert('密码错误');
  }
}

function quickLoginStay() {
  if (isAdminLoggedIn()) {
    alert('您已登录');
    return;
  }
  const pwd = prompt('请输入管理员密码：');
  if (pwd === ADMIN_PWD) {
    saveLoginState();
    location.reload();
  } else if (pwd !== null) {
    alert('密码错误');
  }
}

function openRead(noteId){
  localStorage.setItem('readNoteId', noteId);
  location.href = 'read.html';
}

/* ========== 长按通用封装 ========== */
function bindLongPress(el, onLongPress, onClick){
  let timer = null;
  let longTriggered = false;
  let startX = 0, startY = 0;
  let moved = false;
  const clear = () => {
    clearTimeout(timer);
    timer = null;
  };
  el.addEventListener('touchstart', e => {
    longTriggered = false;
    moved = false;
    const t = e.touches[0];
    startX = t.clientX;
    startY = t.clientY;
    clear();
    timer = setTimeout(() => {
      longTriggered = true;
      onLongPress();
    }, LONG_PRESS_TIME);
  }, { passive: true });
  el.addEventListener('touchmove', e => {
    const t = e.touches[0];
    if (
      Math.abs(t.clientX - startX) > MOVE_THRESHOLD ||
      Math.abs(t.clientY - startY) > MOVE_THRESHOLD
    ) {
      moved = true;
      clear();
    }
  }, { passive: true });
  el.addEventListener('touchend', e => {
    if (!longTriggered && !moved) onClick();
    clear();
  }, { passive: true });
  el.addEventListener('touchcancel', clear, { passive: true });
  el.addEventListener('mousedown', () => {
    longTriggered = false;
    timer = setTimeout(() => {
      longTriggered = true;
      onLongPress();
    }, LONG_PRESS_TIME);
  });
  el.addEventListener('mouseup', () => {
    if (!longTriggered) onClick();
    clear();
  });
  el.addEventListener('mouseleave', clear);
  el.addEventListener('contextmenu', e => {
    e.preventDefault();
    onLongPress();
  });
}

/* ========== 标题长按 ========== */
bindLongPress(
  document.getElementById('secretTrigger'),
  () => {
    if(isAdminLoggedIn()){
      location.href = 'edit.html';
    }else{
      const pwd = prompt('请输入管理员密码：');
      if(pwd === ADMIN_PWD){
        saveLoginState();
        location.href = 'edit.html';
      }else if(pwd!==null){
        alert('密码错误');
      }
    }
  },
  () => {}
);

/* ========== 筛选栏 ========== */
filterHeader.addEventListener('click', () => {
  if (filterJustLongPressed) {
    filterJustLongPressed = false;
    return;
  }
  filterBody.classList.toggle('show');
  filterArrow.classList.toggle('rotate');
});
let filterPressTimer = null;
filterHeader.addEventListener('touchstart', () => {
  filterJustLongPressed = false;
  filterPressTimer = setTimeout(() => {
    filterPressTimer = null;
    filterJustLongPressed = true;
    quickLoginStay();
  }, LONG_PRESS_TIME);
}, { passive: true });
filterHeader.addEventListener('touchend', () => {
  if (filterPressTimer) {
    clearTimeout(filterPressTimer);
    filterPressTimer = null;
  }
});
filterHeader.addEventListener('touchmove', () => {
  if (filterPressTimer) {
    clearTimeout(filterPressTimer);
    filterPressTimer = null;
  }
}, { passive: true });
filterHeader.addEventListener('touchcancel', () => {
  if (filterPressTimer) {
    clearTimeout(filterPressTimer);
    filterPressTimer = null;
  }
});
filterHeader.addEventListener('mousedown', () => {
  filterJustLongPressed = false;
  filterPressTimer = setTimeout(() => {
    filterPressTimer = null;
    filterJustLongPressed = true;
    quickLoginStay();
  }, LONG_PRESS_TIME);
});
filterHeader.addEventListener('mouseup', () => {
  if (filterJustLongPressed) {
    filterJustLongPressed = false;
    if (filterPressTimer) clearTimeout(filterPressTimer);
    filterPressTimer = null;
    return;
  }
  if (filterPressTimer) clearTimeout(filterPressTimer);
  filterPressTimer = null;
});
filterHeader.addEventListener('mouseleave', () => {
  if (filterPressTimer) {
    clearTimeout(filterPressTimer);
    filterPressTimer = null;
  }
});
filterHeader.addEventListener('contextmenu', e => {
  e.preventDefault();
  quickLoginStay();
});
filterBody.addEventListener('click', (e) => {
  if (e.target.classList.contains('filter-btn')) {
    const tag = e.target.dataset.tag;
    if (tag === 'null') filterByTag(null);
    else filterByTag(tag);
  }
});

/* ========== 全屏 ========== */
fullBtn.addEventListener('click', () => {
  if(!document.fullscreenElement){
    document.documentElement.requestFullscreen();
    fullSvg.innerHTML = `<path d="M7 10 H10 V7"/><path d="M17 10 H14 V7"/><path d="M17 14 H14 V17"/><path d="M7 14 H10 V17"/>`;
  }else{
    document.exitFullscreen();
    fullSvg.innerHTML = `<path d="M10 7 H7 V10"/><path d="M14 7 H17 V10"/><path d="M14 17 H17 V14"/><path d="M10 17 H7 V14"/>`;
  }
});

/* ========== 数据加载（优化版） ========== */
async function waitNoteData(){
  for(let i=0;i<20;i++){
    if(window.NOTE_DATA && Array.isArray(window.NOTE_DATA)) return;
    await new Promise(r=>setTimeout(r,50));
  }
}

function loadNoteData(){
  if(window.NOTE_DATA && Array.isArray(window.NOTE_DATA)){
    dataList = JSON.parse(JSON.stringify(window.NOTE_DATA));
    dataList.forEach(item => {
      if (!Array.isArray(item.tags) && item.type) {
        item.tags = [item.type];
      }
      // 缓存预览文本，仅移除图片标签，保留表格结构
      item._preview = getPureTextPreview(item.content);
    });
    localStorage.setItem(LOCAL_NOTE_KEY, JSON.stringify(dataList));
  }else{
    dataList = JSON.parse(localStorage.getItem(LOCAL_NOTE_KEY) || '[]');
  }
  if(isAdminLoggedIn()) logoutBtn.style.display = 'inline-block';
  if(dataList.length === 0){
    wrap.innerHTML = '<div class="empty-tip">暂无笔记</div>';
    return;
  }
  renderFilter();
  // 使用 requestAnimationFrame 延迟渲染，不阻塞主线程
  requestAnimationFrame(() => {
    renderNotes();
  });
}

window.addEventListener('load', async () => {
  await waitNoteData();
  loadNoteData();
});

/* ========== 标签颜色从笔记对象获取 ========== */
function getTagStyle(tagName, colorMap) {
  const color = (colorMap && colorMap[tagName]) || '';
  if (color) {
    const r = parseInt(color.slice(1,3), 16) / 255;
    const g = parseInt(color.slice(3,5), 16) / 255;
    const b = parseInt(color.slice(5,7), 16) / 255;
    const brightness = 0.299 * r + 0.587 * g + 0.114 * b;
    const textColor = brightness > 0.5 ? '#222' : '#fff';
    return `background-color:${color};color:${textColor};border:1px solid ${color};`; // 添加边框
  }
  return '';
}

/* ========== 渲染 ========== */
function renderFilter(){
  allTypes.clear();
  dataList.forEach(i=> (i.tags || []).forEach(t => allTypes.add(t)));
  let html = `<button class="filter-btn ${currentFilterTag===null?'active':''}" onclick="filterByTag(null)" data-tag="null">全部</button>`;
  allTypes.forEach(t=>{
    const escT = escapeHtml(t);
    html += `<button class="filter-btn ${currentFilterTag===t?'active':''}" onclick="filterByTag('${escT}')" data-tag="${escT}">${escT}</button>`;
  });
  filterBody.innerHTML = html;
}

function filterByTag(tagVal){
  currentFilterTag = tagVal;
  renderFilter();
  renderNotes();
}

function getFirstImgFromHtml(html){
  const m = String(html).match(/<img[^>]+src=["']([^"']+)["']/);
  return m ? m[1] : '';
}

// 修改：仅移除图片标签，保留table/tr/td/th等结构标签，让边框样式生效
function getPureTextPreview(html){
  return String(html)
    .replace(/<img[^>]*>/g,'')
    .replace(/\s+/g,' ');
}

function escapeHtml(s){
  return String(s)
    .replace(/&/g,'&amp;')
    .replace(/</g,'&lt;')
    .replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;')
    .replace(/'/g,'&#039;');
}

function renderNotes(){
  let list = dataList.filter(i=>isAdminLoggedIn() || !i.private);
  if(currentFilterTag){
    list = list.filter(item => (item.tags || []).includes(currentFilterTag));
  }
  list.sort((a,b)=>new Date(b.date)-new Date(a.date));
  if(list.length===0){
    wrap.innerHTML = '<div class="empty-tip">暂无笔记</div>';
    return;
  }
  // 使用文档片段构建 DOM，减少重排
  const fragment = document.createDocumentFragment();
  list.forEach(item => {
    const img = item.cover || getFirstImgFromHtml(item.content);
    const imgHtml = img ? `<div class="card-img-box"><img src="${img}"></div>` : '';
    const previewContent = item._preview; // 使用缓存
    const tagHtml = (item.tags || []).map(tag =>
      `<span class="tag-multi" data-tag="${escapeHtml(tag)}" style="${getTagStyle(tag, item.tagColors)}">${escapeHtml(tag)}</span>`
    ).join('');
    const privateHtml = item.private
      ? `<span class="tag-private">🔒 私密</span>`
      : '';
    const div = document.createElement('div');
    div.className = 'note-card';
    div.dataset.id = item.id;
    div.innerHTML = `
      ${imgHtml}
      <div class="card-right-wrap">
        <div class="card-head">
          <div class="card-title">${escapeHtml(item.title)}</div>
          <div class="tag-group">${tagHtml}${privateHtml}</div>
        </div>
        <div class="card-date">${escapeHtml(item.date)}</div>
        <div class="card-preview">${previewContent}</div>
      </div>`;
    fragment.appendChild(div);
  });
  wrap.innerHTML = '';
  wrap.appendChild(fragment);
  // 绑定长按事件
  document.querySelectorAll('.note-card').forEach(card=>{
    bindLongPress(
      card,
      openAdminPage,
      () => openRead(card.dataset.id)
    );
  });
}

logoutBtn.addEventListener('click', () => {
  localStorage.removeItem(PWD_STORE_KEY);
  localStorage.removeItem(LOGIN_EXPIRE_KEY);
  logoutBtn.style.display = 'none';
  renderNotes();
});
</script>
</body>
</html>
