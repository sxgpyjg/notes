<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>笔记目录</title>
<script src="./data.js"></script>
<style>
*{
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: system-ui, -apple-system, sans-serif;
}
body{
  background: #ffffff;
  padding: 0 4px;
  max-width: 1280px;
  margin: 0 auto;
}
header{
  margin-bottom: 8px;
  padding: 8px 6px;
  border-bottom: 1px solid #e4e7f3;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
h1#secretTrigger{
  font-size: 17px;
  color: #1d2133;
  font-weight: 600;
  cursor: pointer;
}
#fullPageBtn{
  width:40px;height:40px;
  border:none;background:transparent;
  display:flex;align-items:center;justify-content:center;
}
#fullPageBtn svg{width:22px;height:22px;}
#fullPageBtn path{
  fill:none;stroke:#9ca3af;
  stroke-width:2;
}

.empty-tip{
  text-align: center;
  padding: 80px 4px;
  color: #888;
}

.note-card{
  background: #fff;
  padding: 12px;
  margin-bottom: 8px;
  border-radius: 16px;
  display: flex;
  gap: 14px;
  cursor: pointer;
}
.note-card:active{background:#f7f8fc;}

.card-img-box{
  width: 100px;
  height: 75px;
  border-radius: 7px;
  overflow: hidden;
  flex-shrink: 0;
  background: #f2f5fc;
}
.card-img-box img{
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.card-right-wrap{
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

/* =======================
   ✅ 标题 + 角标
   ======================= */
.card-head{
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 8px;
}
.card-title{
  font-size: 15px;
  font-weight: 600;
  color: #111827;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ✅ 代码角标（</>） */
.code-badge{
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  font-size: 11px;
  background: #eef2ff;
  color: #6366F1;
  padding: 1px 5px;
  border-radius: 4px;
  margin-right: 6px;
  vertical-align: middle;
  white-space: nowrap;
  flex-shrink: 0;
}

.tag{
  font-size: 10px;
  padding: 2px 7px;
  border-radius: 99px;
  flex-shrink: 0;
}
.tag-note{background:#e8eaff;color:#3950cc;}
.tag-doc{background:#e6f8ee;color:#148246;}
.tag-custom{background:#fff0e6;color:#b8460c;}

.card-date{
  font-size: 10px;
  color: #6b7280;
}

/* =======================
   ✅ 摘要区（表格保留 + 不炸）
   ======================= */
.card-preview{
  font-size: 13px;
  color: #6b7280;
  line-height: 1.35;
  max-height: calc(1.35em * 3);
  overflow: hidden;
  position: relative;
}

/* ✅ 目录页表格：保留但不撑高 */
.card-preview table{
  max-width: 100%;
  width: auto;
  border-collapse: collapse;
  font-size: 12px;
  margin: 4px 0;
  overflow-x: auto;
  display: block;
}
.card-preview th,
.card-preview td{
  border: 1px solid #ddd;
  padding: 3px 6px;
  white-space: nowrap;
}

/* ✅ 代码块：目录页永不显示（保命） */
.card-preview pre,
.card-preview code{
  display: none !important;
}

/* =======================
   筛选面板
   ======================= */
.filter-collapse{
  border:1px solid #dbeafe;
  border-radius:12px;
  margin:0 2px 12px;
  overflow:hidden;
}
.filter-header{
  padding:10px 16px;
  background:#eff6ff;
  cursor:pointer;
  display:flex;
  justify-content:space-between;
  align-items:center;
}
.filter-body{
  padding:12px;
  display:none;
}
.filter-body.show{display:block;}
.arrow{transition:transform 0.24s;}
.arrow.rotate{transform:rotate(180deg);}
.filter-btn{
  padding:6px 11px;
  border:none;
  border-radius:8px;
  margin:4px;
  background:#e0e7ff;
  color:#334155;
}
.filter-btn.active{background:#6366F1;color:#fff;}
</style>
</head>
<body>

<header>
  <h1 id="secretTrigger">笔记目录</h1>
  <button id="fullPageBtn">
    <svg viewBox="0 0 24 24"><path d="M10 7 H7 V10"/><path d="M14 7 H17 V10"/><path d="M14 17 H17 V14"/><path d="M10 17 H7 V14"/></svg>
  </button>
</header>

<div class="filter-collapse">
  <div class="filter-header" onclick="toggleFilterPanel()">
    <span>笔记分类筛选</span>
    <span class="arrow" id="filterArrow">▼</span>
  </div>
  <div class="filter-body" id="filterBody"></div>
</div>

<div class="note-list" id="noteWrap"></div>

<script>
const wrap = document.getElementById('noteWrap');
const dataList = window.NOTE_DATA || [];
let currentFilter = "";

/* =======================
   长按 / 点击逻辑
   ======================= */
let longPressTimer;
const trigger = document.getElementById('secretTrigger');
trigger.addEventListener('contextmenu', e=>e.preventDefault());
trigger.addEventListener('mousedown', ()=>{
  longPressTimer = setTimeout(()=>location.href='edit.html', 2000);
});
trigger.addEventListener('mouseup', ()=>clearTimeout(longPressTimer));
trigger.addEventListener('mouseleave', ()=>clearTimeout(longPressTimer));
trigger.addEventListener('touchstart', ()=>{
  longPressTimer = setTimeout(()=>location.href='edit.html', 2000);
});
trigger.addEventListener('touchend', ()=>clearTimeout(longPressTimer));

trigger.addEventListener('click', ()=>{
  let count = Number(sessionStorage.getItem('clickCount')||0)+1;
  sessionStorage.setItem('clickCount', count);
  if(count>=5){
    sessionStorage.removeItem('clickCount');
    if(localStorage.getItem('admin_save_pwd')==='admin123'){
      location.href='admin-list.html';
    }else{
      const pwd=prompt('管理员密码');
      if(pwd==='admin123'){
        localStorage.setItem('admin_save_pwd',pwd);
        location.href='admin-list.html';
      }
    }
  }
  setTimeout(()=>sessionStorage.removeItem('clickCount'),2000);
});

/* =======================
   工具函数
   ======================= */
function getFirstImgFromHtml(h){
  const m=h.match(/<img[^>]+src=['"]([^'"]+)['"][^>]*>/);
  return m?m[1]:'';
}

function getPureTextPreview(h){
  if(!h) return '';
  return h.replace(/```[\s\S]*?```/g,'')
         .replace(/`[^`]+`/g,'')
         .replace(/<[^>]+>/g,'')
         .replace(/\s+/g,' ')
         .trim();
}

/* =======================
   渲染
   ======================= */
function renderFilter(){
  const types=[...new Set(dataList.filter(i=>i.type).map(i=>i.type))];
  let html='<button class="filter-btn active" onclick="filterByType(\'\')">全部</button>';
  types.forEach(t=>html+=`<button class="filter-btn" onclick="filterByType('${t}')">${t}</button>`);
  document.getElementById('filterBody').innerHTML=html;
}

function filterByType(t){
  currentFilter=t;
  document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));
  renderNotes();
}

function openRead(id){
  localStorage.setItem('readNoteId',id);
  location.href='read.html';
}

function renderNotes(){
  let list=dataList.filter(i=>!currentFilter||i.type===currentFilter);
  list.sort((a,b)=>new Date(b.date)-new Date(a.date));

  if(!list.length){
    wrap.innerHTML='<div class="empty-tip">暂无笔记</div>';
    return;
  }

  wrap.innerHTML=list.map(item=>{
    const hasCode=/```/.test(item.content);
    const img=item.cover||getFirstImgFromHtml(item.content);
    const preview=getPureTextPreview(item.content);

    let tagClass='tag-custom',tagText=item.type;
    if(item.type==='note'){tagClass='tag-note';tagText='开发笔记';}
    if(item.type==='doc'){tagClass='tag-doc';tagText='实操教程';}

    return `
    <div class="note-card" onclick="openRead('${item.id}')">
      ${img?`<div class="card-img-box"><img src="${img}"></div>`:''}
      <div class="card-right-wrap">
        <div class="card-head">
          <div class="card-title">
            ${item.title}
            <span class="code-badge" style="display:${hasCode?'inline':'none'}">&lt;/&gt;</span>
          </div>
          <span class="tag ${tagClass}">${tagText}</span>
        </div>
        <div class="card-date">${item.date}</div>
        <div class="card-preview">${preview}</div>
      </div>
    </div>
    `;
  }).join('');
}

function toggleFilterPanel(){
  const b=document.getElementById('filterBody'),a=document.getElementById('filterArrow');
  b.classList.toggle('show');a.classList.toggle('rotate');
}

renderFilter();
renderNotes();
</script>
</body>
</html>
